# IntelOS — Environment Variables
# Copy this to .env and fill in your keys.

# =============================================================
# MEETING RECORDER (choose one — leave the other blank)
# =============================================================

# Option A: Fireflies.ai
# Get your key at: https://app.fireflies.ai/integrations → API & Webhooks → copy API Key
FIREFLIES_API_KEY=

# Option B: Fathom
# Get your key at: https://app.fathom.ai/settings → Integrations → API → Generate API Key
FATHOM_API_KEY=

# =============================================================
# SLACK (optional — skip if you don't use Slack)
# =============================================================

# Slack Bot User OAuth Token (starts with xoxb- or xoxp-)
# Create a Slack app at: https://api.slack.com/apps
# Required scopes: channels:history, channels:read, channels:join, users:read
# You can add multiple workspaces — just add more SLACK_TOKEN_ variables
SLACK_TOKEN_MAIN=
